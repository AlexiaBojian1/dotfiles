#!/bin/bash
# Power menu using rofi

lock="箚뙻 Lock"
logout="箚뛽 Logout"
reboot="箚쐣 Reboot"
shutdown="箚맓 Shutdown"

chosen=$(printf '%s\n' "$lock" "$logout" "$reboot" "$shutdown" \
    | rofi -dmenu -p "Power" -theme-str 'window {width: 200px;}')

case "$chosen" in
    "$lock")     hyprlock ;;
    "$logout")   hyprctl dispatch exit ;;
    "$reboot")   systemctl reboot ;;
    "$shutdown")  systemctl poweroff ;;
esac
